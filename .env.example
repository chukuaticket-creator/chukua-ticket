# ─── Chukua Ticket Environment Variables ───────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it's in .gitignore already.

# Paystack Public Key (safe to expose on frontend)
# Get from: https://dashboard.paystack.com/#/settings/developers
VITE_PAYSTACK_PUBLIC_KEY=pk_live_YOUR_KEY_HERE

# Your backend API URL (when you build one)
# VITE_API_URL=https://api.chukuaticket.co.ke
